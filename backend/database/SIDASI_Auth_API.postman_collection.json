{
  "info": {
    "_postman_id": "sidasi-auth-api",
    "name": "SIDASI Auth API",
    "description": "Testing auth endpoints: register, login, me, forgot-password, reset-password",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  pm.test('Register success', () => {",
              "    pm.expect(pm.response.json().message).to.include('berhasil');",
              "  });",
              "}",
              "pm.test('Response has message', () => {",
              "  pm.expect(pm.response.json()).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "name",
              "value": "Budi Santoso",
              "type": "text"
            },
            {
              "key": "email",
              "value": "budi@example.com",
              "type": "text"
            },
            {
              "key": "password",
              "value": "Password123",
              "type": "text"
            },
            {
              "key": "confirmPassword",
              "value": "Password123",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const token = pm.response.json().token;",
              "  pm.environment.set('token', token);",
              "  pm.test('Login success and token saved', () => {",
              "    pm.expect(token).to.be.a('string');",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "email",
              "value": "budi@example.com",
              "type": "text"
            },
            {
              "key": "password",
              "value": "Password123",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Get Current User (Me)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        }
      }
    },
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "email",
              "value": "budi@example.com",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/auth/forgot-password",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "forgot-password"]
        }
      }
    },
    {
      "name": "Reset Password",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Sebelum pakai endpoint ini, kamu perlu copy token dari console backend saat forgot-password dipanggil.",
              "// Token ada di log: [ResetToken] email@example.com -> TOKEN_STRING",
              "// Tulis token tsb di field 'token' di bawah."
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "token",
              "value": "PASTE_RESET_TOKEN_FROM_CONSOLE_HERE",
              "type": "text"
            },
            {
              "key": "newPassword",
              "value": "NewPassword456",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/auth/reset-password",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "reset-password"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
